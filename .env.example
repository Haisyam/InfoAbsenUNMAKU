# Ubah ke false kalau ingin benar-benar kirim notifikasi Telegram
DRY_RUN=true

# Cek ulang tiap berapa menit
CHECK_INTERVAL_MINUTES=5

# Timezone default untuk evaluasi jadwal matkul
DEFAULT_TIMEZONE=Asia/Jakarta

# Mode notifikasi: critical (hanya Alfa/Unknown) atau all (semua perubahan)
NOTIFY_MODE=critical

# Channel notifikasi: telegram | whatsapp | both
NOTIFIER_CHANNEL=telegram

# Aktifkan command bot (/start, /info, tombol Rekap Absensi)
TELEGRAM_ENABLE_BOT=true

# Interval polling update Telegram (detik)
TELEGRAM_POLL_SECONDS=5

# Batasi chat id yang boleh akses command bot (pisahkan dengan koma)
# Default akan pakai TELEGRAM_CHAT_ID jika kosong
TELEGRAM_ALLOWED_CHAT_IDS=

# Isi token bot telegram dan chat id kamu
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== WhatsApp (Baileys) =====
# Aktifkan integrasi WhatsApp
WHATSAPP_ENABLE=false

# Nomor tujuan notifikasi WA, pisah koma (contoh: 6281234567890,6289999999999)
WHATSAPP_TARGETS=

# Nomor yang boleh kirim command WA (info/rekap/menu), pisah koma
# Jika kosong, semua private chat diizinkan
WHATSAPP_ALLOWED_SENDERS=

# Simpan auth session Baileys
WHATSAPP_AUTH_DIR=state/wa_auth

# Aktifkan command WA (info/rekap/menu)
WHATSAPP_COMMAND_ENABLE=true
